rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             (data.displayName == null || data.displayName is string) &&
             (data.photoURL == null || data.photoURL is string);
    }

    function isValidChat(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    function isValidMessage(data) {
      return data.content is string && data.content.size() <= 10000 &&
             data.role in ['user', 'model'] &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'settings', 'subscription']);
      
      match /chats/{chatId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(chatId) && isValidChat(incoming());
        allow update: if isOwner(userId) && isValidId(chatId) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']) &&
                      incoming().updatedAt == request.time;
        allow delete: if isOwner(userId);

        match /messages/{messageId} {
          allow list: if isOwner(userId);
          allow get: if isOwner(userId);
          allow create: if isOwner(userId) && isValidId(messageId) && isValidMessage(incoming());
        }
      }
    }
  }
}
